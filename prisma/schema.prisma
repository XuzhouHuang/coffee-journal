generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Region {
  id        Int      @id @default(autoincrement())
  country   String   @db.NVarChar(255)
  region    String   @db.NVarChar(255)
  subRegion String?  @db.NVarChar(255)
  altitude  String?  @db.NVarChar(255)
  climate   String?  @db.NVarChar(255)
  notes     String?  @db.NVarChar(Max)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  beans     Bean[]

  @@unique([country, region])
}

model Variety {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.NVarChar(255)
  description String?  @db.NVarChar(Max)
  flavor      String?  @db.NVarChar(Max)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  beans       Bean[]
}

model Roaster {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.NVarChar(255)
  country   String   @db.NVarChar(255)
  specialty String?  @db.NVarChar(255)
  website   String?  @db.NVarChar(255)
  shopUrl   String?  @db.NVarChar(255)
  notes     String?  @db.NVarChar(Max)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  beans     Bean[]
}

model Bean {
  id          Int            @id @default(autoincrement())
  name        String         @db.NVarChar(255)
  roasterId   Int?
  regionId    Int?
  varietyId    Int?
  origin      String?        @db.NVarChar(500)
  altitude    String?        @db.NVarChar(100)
  species     String?        @db.NVarChar(100)
  process     String?        @db.NVarChar(255)
  roastLevel  String?        @db.NVarChar(255)
  roastInfo   String?        @db.NVarChar(500)
  producer    String?        @db.NVarChar(500)
  station     String?        @db.NVarChar(255)
  batch       String?        @db.NVarChar(255)
  flavorNotes String?        @db.NVarChar(Max)
  score       Float?
  status      String?        @db.NVarChar(50)
  notes       String?        @db.NVarChar(Max)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  roaster     Roaster?       @relation(fields: [roasterId], references: [id])
  region      Region?        @relation(fields: [regionId], references: [id])
  variety     Variety?       @relation(fields: [varietyId], references: [id])
  purchases   BeanPurchase[]
  brewLogs    BrewLog[]
}

model BeanPurchase {
  id           Int      @id @default(autoincrement())
  beanId       Int
  price        Float
  weight       Int
  purchaseDate DateTime
  source       String?  @db.NVarChar(255)
  notes        String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bean         Bean     @relation(fields: [beanId], references: [id], onDelete: Cascade)
}

model BrewLog {
  id          Int      @id @default(autoincrement())
  beanId      Int
  brewMethod  String   @db.NVarChar(255)
  dose        Float?
  waterAmount Float?
  ratio       String?  @db.NVarChar(255)
  grindSize   String?  @db.NVarChar(255)
  waterTemp   Int?
  brewTime    String?  @db.NVarChar(255)
  rating      Float?
  notes       String?  @db.NVarChar(Max)
  brewDate    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bean        Bean     @relation(fields: [beanId], references: [id], onDelete: Cascade)
}

model ProcessingMethod {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.NVarChar(255)
  description String?  @db.NVarChar(Max)
  flavorNotes String?  @db.NVarChar(Max)
  suitable    String?  @db.NVarChar(Max)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EquipmentPurchase {
  id           Int      @id @default(autoincrement())
  name         String   @db.NVarChar(255)
  category     String   @db.NVarChar(255) // 滤杯/手冲壶/磨豆机/电子秤/滤纸/其他
  brand        String?  @db.NVarChar(255)
  price        Float
  purchaseDate DateTime
  source       String?  @db.NVarChar(255) // 购买渠道
  notes        String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CafePurchase {
  id           Int      @id @default(autoincrement())
  cafeName     String   @db.NVarChar(255)
  location     String?  @db.NVarChar(255)
  drinkName    String   @db.NVarChar(255)
  drinkType    String?  @db.NVarChar(255)
  price        Float
  purchaseDate DateTime
  rating       Float?
  notes        String?  @db.NVarChar(Max)
  photo        String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BreadPurchase {
  id           Int      @id @default(autoincrement())
  bakeryName   String   @db.NVarChar(255)
  location     String?  @db.NVarChar(255)
  breadName    String   @db.NVarChar(255)
  breadType    String?  @db.NVarChar(255)
  price        Float
  purchaseDate DateTime
  notes        String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BreadRecipe {
  id           Int      @id @default(autoincrement())
  name         String   @db.NVarChar(255)
  breadType    String?  @db.NVarChar(255)
  ingredients  String   @db.NVarChar(Max)
  steps        String   @db.NVarChar(Max)
  fermentation String?  @db.NVarChar(255)
  bakingTemp   Int?
  bakingTime   String?  @db.NVarChar(255)
  difficulty   String?  @db.NVarChar(255)
  tips         String?  @db.NVarChar(Max)
  notes        String?  @db.NVarChar(Max)
  rating       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CoffeeNews {
  id        Int      @id @default(autoincrement())
  title     String   @db.NVarChar(500)
  titleZh   String   @db.NVarChar(500)
  source    String   @db.NVarChar(255)
  url       String   @db.NVarChar(1000)
  summary   String?  @db.NVarChar(Max)
  content   String?  @db.NVarChar(Max)
  newsDate  DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([newsDate(sort: Desc)])
}
